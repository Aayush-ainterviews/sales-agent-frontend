# Copy to .env.local and fill in. These are SERVER-SIDE only (no NEXT_PUBLIC_ prefix),
# so the bearer token never reaches the browser — the Next.js /api/* routes use them.

# The deployed backend
BACKEND_URL=https://sales-agent-production-ddbd.up.railway.app

# Must match ONE entry of the backend's USER_TOKENS (Railway).
# e.g. backend USER_TOKENS="tok_rohan:rohan"  ->  BACKEND_USER_ID=rohan, BACKEND_TOKEN=tok_rohan
BACKEND_USER_ID=rohan
BACKEND_TOKEN=tok_rohan
