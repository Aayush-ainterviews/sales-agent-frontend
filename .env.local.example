# Copy to .env.local and fill in.

# --- Clerk (auth) ---
# From Clerk Dashboard -> API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Where Clerk sends users for auth (matches the /sign-in, /sign-up pages).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Backend (direct-connect) ---
# The browser streams straight from this origin with a Clerk JWT (no proxy, no 60s cap).
# Must be set in Vercel too (NEXT_PUBLIC_ = baked into the browser bundle at build time).
NEXT_PUBLIC_BACKEND_URL=https://sales-agent-production-ddbd.up.railway.app
